{
  "extends": "./tsconfig/nextjs.json",
  "compilerOptions": {
    "strict": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/core": ["../../packages/core"],
      "@/core/*": ["../../packages/core/*"],
      "@reacteditor/core": ["../../packages/core"],
      "@reacteditor/plugin-ai": ["../../packages/plugin-ai/src"],
      "@reacteditor/plugin-ai/server": ["../../packages/plugin-ai/src/server"],
      "@reacteditor/plugin-media": ["../../packages/plugin-media/src"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
