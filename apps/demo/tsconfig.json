{
  "extends": "./tsconfig/nextjs.json",
  "compilerOptions": {
    "strict": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/core": ["../../packages/core"],
      "@/core/*": ["../../packages/core/*"],
      "@frontendai/react-editor": ["../../packages/core"],
      "@/field-shopify": ["../../packages/field-shopify"],
      "@/field-shopify/*": ["../../packages/field-shopify/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
