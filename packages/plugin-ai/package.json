{
  "name": "@reacteditor/plugin-ai",
  "version": "0.0.3",
  "author": "Rami Bitar <rami@frontend.co>",
  "repository": "frontend-inc/react-editor",
  "bugs": "https://github.com/frontend-inc/react-editor/issues",
  "homepage": "https://frontend.co",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint \"**/*.ts*\"",
    "build": "rm -rf dist && tsup src/index.tsx src/server.ts",
    "test": "jest",
    "prepare": "yarn build"
  },
  "dependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/react": "3.0.71",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "use-stick-to-bottom": "^1.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@reacteditor/core": "*",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.0.2",
    "eslint": "^7.32.0",
    "eslint-config-custom": "*",
    "tsconfig": "*",
    "tsup": "^8.2.4",
    "tsup-config": "*",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "lucide-react": "^0.468.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
